---
import { getLangFromLocale, useTranslations } from '../i18n/utils';

const lang = getLangFromLocale(Astro.currentLocale);
const t = useTranslations(lang);

const useCases = [
	{
		title: t('useCases.1.title'),
		bullets: [t('useCases.1.bullet1'), t('useCases.1.bullet2'), t('useCases.1.bullet3')],
		accent: '#075E54',
		icon: `<path d="M3 21l1.65-3.8a9 9 0 1 1 3.4 2.9L3 21" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/><path d="M12 12v-2M12 16h.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>`,
	},
	{
		title: t('useCases.2.title'),
		bullets: [t('useCases.2.bullet1'), t('useCases.2.bullet2'), t('useCases.2.bullet3')],
		accent: '#128C7E',
		icon: `<rect x="2" y="7" width="20" height="14" rx="2" ry="2" stroke="currentColor" stroke-width="1.5" fill="none"/><path d="M16 7V5a4 4 0 0 0-8 0v2" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"/><path d="M12 14v2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="12" cy="14" r="1" fill="currentColor"/>`,
	},
	{
		title: t('useCases.3.title'),
		bullets: [t('useCases.3.bullet1'), t('useCases.3.bullet2'), t('useCases.3.bullet3')],
		accent: '#25D366',
		icon: `<path d="M22 10v6M2 10l10-5 10 5-10 5z" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/><path d="M6 12v5c0 1.657 2.686 3 6 3s6-1.343 6-3v-5" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>`,
	},
];
---

<section class="use-cases" id="use-cases">
	<div class="container">
		<div class="section-header reveal">
			<p class="eyebrow">{t('useCases.eyebrow')}</p>
			<h2>{t('useCases.title')}</h2>
		</div>
		<div class="cases-grid">
			{useCases.map((uc, i) => (
				<div class={`case-card reveal reveal-delay-${i + 1}`}>
					<div class="case-accent" style={`background: ${uc.accent};`}></div>
					<div class="case-icon" style={`color: ${uc.accent};`}>
						<svg width="28" height="28" viewBox="0 0 24 24" fill="none" aria-hidden="true" set:html={uc.icon} />
					</div>
					<h3>{uc.title}</h3>
					<ul>
						{uc.bullets.map(bullet => (
							<li>
								<svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
									<path d="M13.333 4L6 11.333 2.667 8" stroke="#25D366" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
								</svg>
								{bullet}
							</li>
						))}
					</ul>
				</div>
			))}
		</div>
	</div>
</section>

<style>
	.use-cases {
		padding: var(--space-2xl) var(--space-md);
	}

	.container {
		max-width: 1100px;
		margin: 0 auto;
	}

	.section-header {
		margin-bottom: var(--space-xl);
	}

	.eyebrow {
		margin-bottom: var(--space-sm);
	}

	h2 {
		font-size: var(--font-size-3xl);
	}

	.cases-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--space-md);
	}

	.case-card {
		background: var(--color-bg-alt);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		padding: 0 var(--space-md) var(--space-lg);
		transition: box-shadow var(--transition-normal), transform var(--transition-normal);
		overflow: hidden;
		position: relative;
	}

	.case-card:hover {
		box-shadow: 0 12px 40px rgba(0, 0, 0, 0.08);
		transform: translateY(-4px);
	}

	.case-accent {
		height: 4px;
		margin: 0 calc(-1 * var(--space-md));
		margin-bottom: var(--space-md);
	}

	.case-icon {
		width: 52px;
		height: 52px;
		border-radius: var(--radius-md);
		background: rgba(7, 94, 84, 0.06);
		display: flex;
		align-items: center;
		justify-content: center;
		margin-bottom: var(--space-sm);
	}

	h3 {
		font-family: var(--font-body);
		font-weight: 600;
		font-size: var(--font-size-lg);
		margin-bottom: var(--space-sm);
		line-height: var(--line-height-snug);
	}

	ul {
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: var(--space-xs);
	}

	li {
		display: flex;
		align-items: flex-start;
		gap: 8px;
		font-size: var(--font-size-sm);
		color: var(--color-text-secondary);
		line-height: var(--line-height-normal);
	}

	li svg {
		flex-shrink: 0;
		margin-top: 3px;
	}

	@media (max-width: 768px) {
		.cases-grid {
			grid-template-columns: 1fr;
			gap: var(--space-sm);
		}

		h2 {
			font-size: var(--font-size-2xl);
		}
	}
</style>
