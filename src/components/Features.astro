---
import { getLangFromLocale, useTranslations } from '../i18n/utils';

const lang = getLangFromLocale(Astro.currentLocale);
const t = useTranslations(lang);

const features = [
	{
		title: t('features.1.title'),
		description: t('features.1.description'),
		icon: `<path d="M12 2a8 8 0 0 0-8 8c0 3.4 2.1 6.3 5.1 7.5.1-.3.2-.7.2-1V15c-.4 0-1.1 0-1.3 0-.7 0-1.3-.3-1.6-.9-.4-.6-.4-1.5-1.1-2-.2-.2 0-.4.2-.4.5.1.9.5 1.3 1 .4.6.5.7 1.2.7.3 0 .8 0 1.2-.2.1-.7.5-1.3 1-1.6C7 11.7 5 10.7 5 8.1c0-1 .4-2 1-2.7-.1-.3-.5-1.3.1-2.6 0 0 .8-.3 2.7 1a9.2 9.2 0 0 1 4.8-.1c.5-.3 1.9-1.1 2.7-.9.5 1.3.2 2.3.1 2.5.7.8 1.1 1.7 1.1 2.7 0 2.7-2 3.7-4.2 4 .5.4.8 1.2.8 2v2.8c0 .2 0 .4.1.6A8 8 0 0 0 20 10a8 8 0 0 0-8-8z" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>`,
		size: 'large',
	},
	{
		title: t('features.2.title'),
		description: t('features.2.description'),
		icon: `<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="1.5"/><path d="M22 21v-2a4 4 0 0 0-3-3.87" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M16 3.13a4 4 0 0 1 0 7.75" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>`,
		size: 'large',
	},
	{
		title: t('features.3.title'),
		description: t('features.3.description'),
		icon: `<path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M8 7h8M8 11h5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>`,
		size: 'small',
	},
	{
		title: t('features.4.title'),
		description: t('features.4.description'),
		icon: `<rect x="3" y="3" width="18" height="18" rx="2" ry="2" stroke="currentColor" stroke-width="1.5" fill="none"/><line x1="3" y1="9" x2="21" y2="9" stroke="currentColor" stroke-width="1.5"/><line x1="9" y1="21" x2="9" y2="9" stroke="currentColor" stroke-width="1.5"/>`,
		size: 'small',
	},
	{
		title: t('features.5.title'),
		description: t('features.5.description'),
		icon: `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/><path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>`,
		size: 'small',
	},
	{
		title: t('features.6.title'),
		description: t('features.6.description'),
		icon: `<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/><path d="M8 10h.01M12 10h.01M16 10h.01" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>`,
		size: 'small',
	},
];
---

<section class="features" id="features">
	<div class="features-container">
		<div class="features-header reveal">
			<p class="eyebrow">{t('features.eyebrow')}</p>
			<h2>{t('features.title')}</h2>
		</div>
		<div class="bento-grid">
			{features.map((feature, i) => (
				<div class={`feature-card ${feature.size} reveal reveal-delay-${(i % 3) + 1}`}>
					<div class="feature-icon">
						<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true" set:html={feature.icon} />
					</div>
					<h3>{feature.title}</h3>
					<p>{feature.description}</p>
				</div>
			))}
		</div>
	</div>
</section>

<style>
	.features {
		padding: var(--space-2xl) var(--space-md);
	}

	.features-container {
		max-width: 1100px;
		margin: 0 auto;
	}

	.features-header {
		margin-bottom: var(--space-xl);
	}

	.eyebrow {
		margin-bottom: var(--space-sm);
	}

	h2 {
		font-size: var(--font-size-3xl);
		max-width: 600px;
	}

	/* Bento grid: 2 large cards on top, 4 small below */
	.bento-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: var(--space-sm);
	}

	.feature-card {
		padding: var(--space-md) var(--space-md) var(--space-lg);
		border-radius: var(--radius-lg);
		background: var(--color-bg-alt);
		border: 1px solid var(--color-border);
		transition: box-shadow var(--transition-normal), transform var(--transition-normal), border-color var(--transition-normal);
	}

	.feature-card:hover {
		box-shadow: 0 8px 30px rgba(7, 94, 84, 0.08);
		transform: translateY(-2px);
		border-color: rgba(7, 94, 84, 0.15);
	}

	.feature-card.large {
		grid-column: span 2;
	}

	.feature-card.small {
		grid-column: span 1;
	}

	.feature-icon {
		width: 48px;
		height: 48px;
		border-radius: var(--radius-md);
		background: rgba(7, 94, 84, 0.08);
		display: flex;
		align-items: center;
		justify-content: center;
		margin-bottom: var(--space-sm);
		color: var(--color-primary);
		transition: background-color var(--transition-normal);
	}

	.feature-card:hover .feature-icon {
		background: rgba(7, 94, 84, 0.12);
	}

	h3 {
		font-family: var(--font-body);
		font-weight: 600;
		font-size: var(--font-size-md);
		margin-bottom: var(--space-xs);
		line-height: var(--line-height-snug);
	}

	p {
		font-size: var(--font-size-sm);
		color: var(--color-text-secondary);
		line-height: var(--line-height-relaxed);
	}

	@media (max-width: 768px) {
		.bento-grid {
			grid-template-columns: 1fr;
			gap: var(--space-sm);
		}

		.feature-card.large,
		.feature-card.small {
			grid-column: span 1;
		}

		h2 {
			font-size: var(--font-size-2xl);
		}
	}
</style>
