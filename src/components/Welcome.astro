---
import astroLogo from '../assets/astro.svg';
import background from '../assets/background.svg';
import { getLangFromLocale, useTranslations, getLocalePath, getAlternateLang } from '../i18n/utils';

const lang = getLangFromLocale(Astro.currentLocale);
const t = useTranslations(lang);
const altLang = getAlternateLang(lang);
---

<div id="container">
	<img id="background" src={background.src} alt="" fetchpriority="high" />

	<nav>
		<a href={getLocalePath(lang)}>{t('nav.home')}</a>
		<a href={getLocalePath(lang, 'features')}>{t('nav.features')}</a>
		<a href={getLocalePath(lang, 'pricing')}>{t('nav.pricing')}</a>
		<a href={getLocalePath(lang, 'contact')}>{t('nav.contact')}</a>
		<a href={getLocalePath(altLang)} class="lang-switch">{t('lang.switch')}</a>
	</nav>

	<main>
		<section id="hero">
			<h1>{t('hero.title')}</h1>
			<p class="subtitle">{t('hero.subtitle')}</p>
			<section id="links">
				<a class="button" href={getLocalePath(lang, 'contact')}>{t('hero.cta')}</a>
				<a href={getLocalePath(lang, 'features')}>{t('hero.cta.secondary')}</a>
			</section>
		</section>
	</main>
</div>

<style>
	#background {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: -1;
		filter: blur(100px);
	}

	#container {
		font-family: Inter, Roboto, 'Helvetica Neue', 'Arial Nova', 'Nimbus Sans', Arial, sans-serif;
		height: 100%;
	}

	nav {
		display: flex;
		align-items: center;
		gap: 24px;
		padding: 16px 32px;
	}

	nav a {
		color: #111827;
		text-decoration: none;
		font-size: 14px;
		font-weight: 500;
		transition: color 0.2s;
	}

	nav a:hover {
		color: rgb(78, 80, 86);
	}

	nav .lang-switch {
		margin-left: auto;
		padding: 6px 12px;
		border: 1px solid #d1d5db;
		border-radius: 6px;
		font-size: 12px;
		font-weight: 600;
		letter-spacing: 0.05em;
	}

	nav .lang-switch:hover {
		background: rgba(255, 255, 255, 0.6);
	}

	main {
		height: calc(100% - 56px);
		display: flex;
		justify-content: center;
	}

	#hero {
		display: flex;
		align-items: start;
		flex-direction: column;
		justify-content: center;
		padding: 16px;
		max-width: 640px;
	}

	h1 {
		font-size: 40px;
		line-height: 1.2;
		margin-top: 0;
		margin-bottom: 16px;
		color: #111827;
	}

	.subtitle {
		font-size: 18px;
		color: #4b5563;
		line-height: 1.6;
		margin-bottom: 32px;
	}

	#links {
		display: flex;
		gap: 16px;
	}

	#links a {
		display: flex;
		align-items: center;
		padding: 10px 12px;
		color: #111827;
		text-decoration: none;
		transition: color 0.2s;
	}

	#links a:hover {
		color: rgb(78, 80, 86);
	}

	#links a.button {
		color: white;
		background: linear-gradient(83.21deg, #3245ff 0%, #bc52ee 100%);
		box-shadow:
			inset 0 0 0 1px rgba(255, 255, 255, 0.12),
			inset 0 -2px 0 rgba(0, 0, 0, 0.24);
		border-radius: 10px;
		padding: 14px 24px;
		font-weight: 600;
	}

	#links a.button:hover {
		color: rgb(230, 230, 230);
		box-shadow: none;
	}

	@media screen and (max-width: 768px) {
		nav {
			padding: 12px 16px;
			gap: 16px;
			flex-wrap: wrap;
		}

		#hero {
			padding: 16px;
		}

		h1 {
			font-size: 28px;
		}

		#links {
			flex-wrap: wrap;
		}

		#links a.button {
			padding: 14px 18px;
		}
	}
</style>
