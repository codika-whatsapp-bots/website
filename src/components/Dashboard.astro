---
import { getLangFromLocale, useTranslations } from '../i18n/utils';

const lang = getLangFromLocale(Astro.currentLocale);
const t = useTranslations(lang);

const bullets = [
	t('dashboard.bullet1'),
	t('dashboard.bullet2'),
	t('dashboard.bullet3'),
	t('dashboard.bullet4'),
	t('dashboard.bullet5'),
];
---

<section class="dashboard">
	<div class="container">
		<div class="dashboard-text reveal">
			<p class="eyebrow">{t('dashboard.eyebrow')}</p>
			<h2>{t('dashboard.title')}</h2>
			<p class="dashboard-description">{t('dashboard.description')}</p>
			<ul>
				{bullets.map((bullet, i) => (
					<li>
						<svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
							<circle cx="10" cy="10" r="10" fill="rgba(7, 94, 84, 0.08)"/>
							<path d="M14 7.5L8.5 13 6 10.5" stroke="#075E54" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
						</svg>
						{bullet}
					</li>
				))}
			</ul>
		</div>
		<div class="dashboard-visual reveal reveal-delay-2">
			<div class="dashboard-glow"></div>
			<div class="dashboard-placeholder">
				<div class="placeholder-header">
					<div class="placeholder-dots">
						<div class="placeholder-dot red"></div>
						<div class="placeholder-dot yellow"></div>
						<div class="placeholder-dot green"></div>
					</div>
				</div>
				<div class="placeholder-sidebar">
					<div class="placeholder-nav-item active"></div>
					<div class="placeholder-nav-item"></div>
					<div class="placeholder-nav-item"></div>
					<div class="placeholder-nav-item"></div>
					<div class="placeholder-nav-item"></div>
				</div>
				<div class="placeholder-content">
					<div class="placeholder-stat-row">
						<div class="placeholder-stat">
							<div class="stat-bar" style="width: 60%;"></div>
						</div>
						<div class="placeholder-stat">
							<div class="stat-bar" style="width: 80%;"></div>
						</div>
						<div class="placeholder-stat">
							<div class="stat-bar" style="width: 45%;"></div>
						</div>
						<div class="placeholder-stat">
							<div class="stat-bar" style="width: 70%;"></div>
						</div>
					</div>
					<div class="placeholder-table">
						<div class="placeholder-row header"></div>
						<div class="placeholder-row shimmer"></div>
						<div class="placeholder-row shimmer"></div>
						<div class="placeholder-row shimmer"></div>
						<div class="placeholder-row shimmer"></div>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	.dashboard {
		padding: var(--space-2xl) var(--space-md);
		background-color: var(--color-bg-alt);
	}

	.container {
		max-width: 1100px;
		margin: 0 auto;
		display: grid;
		grid-template-columns: 1fr 1.2fr;
		gap: var(--space-xl);
		align-items: center;
	}

	.eyebrow {
		margin-bottom: var(--space-sm);
	}

	h2 {
		font-size: var(--font-size-3xl);
		margin-bottom: var(--space-sm);
	}

	.dashboard-description {
		font-size: var(--font-size-base);
		color: var(--color-text-secondary);
		margin-bottom: var(--space-md);
		line-height: var(--line-height-relaxed);
	}

	ul {
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 12px;
	}

	li {
		display: flex;
		align-items: center;
		gap: 12px;
		font-size: var(--font-size-sm);
		color: var(--color-text-secondary);
		line-height: var(--line-height-normal);
	}

	li svg {
		flex-shrink: 0;
	}

	/* Dashboard visual */
	.dashboard-visual {
		position: relative;
	}

	.dashboard-glow {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		width: 110%;
		height: 110%;
		background: radial-gradient(
			ellipse at center,
			rgba(7, 94, 84, 0.06) 0%,
			rgba(7, 94, 84, 0.02) 50%,
			transparent 70%
		);
		border-radius: 50%;
		pointer-events: none;
	}

	.dashboard-placeholder {
		background: var(--color-bg);
		border-radius: var(--radius-xl);
		box-shadow:
			0 20px 60px rgba(0, 0, 0, 0.1),
			0 0 0 1px rgba(0, 0, 0, 0.03);
		overflow: hidden;
		aspect-ratio: 16 / 11;
		display: grid;
		grid-template-columns: 60px 1fr;
		grid-template-rows: 32px 1fr;
		position: relative;
		z-index: 1;
	}

	.placeholder-header {
		grid-column: 1 / -1;
		background: var(--color-bg-subtle);
		display: flex;
		align-items: center;
		padding: 0 12px;
	}

	.placeholder-dots {
		display: flex;
		gap: 6px;
	}

	.placeholder-dot {
		width: 8px;
		height: 8px;
		border-radius: 50%;
	}

	.placeholder-dot.red { background: #FF5F57; }
	.placeholder-dot.yellow { background: #FFBD2E; }
	.placeholder-dot.green { background: #28CA42; }

	.placeholder-sidebar {
		background: rgba(7, 94, 84, 0.06);
		padding: 12px 8px;
		display: flex;
		flex-direction: column;
		gap: 8px;
	}

	.placeholder-nav-item {
		height: 8px;
		border-radius: 4px;
		background: rgba(7, 94, 84, 0.12);
		transition: background-color var(--transition-normal);
	}

	.placeholder-nav-item.active {
		background: rgba(7, 94, 84, 0.35);
	}

	.placeholder-content {
		padding: 16px;
		display: flex;
		flex-direction: column;
		gap: 16px;
	}

	.placeholder-stat-row {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 8px;
	}

	.placeholder-stat {
		height: 40px;
		border-radius: var(--radius-sm);
		background: rgba(7, 94, 84, 0.04);
		border: 1px solid rgba(7, 94, 84, 0.06);
		padding: 28px 8px 8px;
		overflow: hidden;
	}

	.stat-bar {
		height: 4px;
		border-radius: 2px;
		background: linear-gradient(90deg, var(--color-primary-accent) 0%, var(--color-primary-light) 100%);
		opacity: 0.6;
	}

	.placeholder-table {
		flex: 1;
		display: flex;
		flex-direction: column;
		gap: 4px;
	}

	.placeholder-row {
		height: 20px;
		border-radius: 4px;
		background: rgba(17, 17, 19, 0.04);
	}

	.placeholder-row.header {
		background: rgba(7, 94, 84, 0.1);
		height: 24px;
	}

	/* Subtle shimmer on rows */
	.placeholder-row.shimmer {
		position: relative;
		overflow: hidden;
	}

	.placeholder-row.shimmer::after {
		content: '';
		position: absolute;
		top: 0;
		left: -100%;
		width: 100%;
		height: 100%;
		background: linear-gradient(90deg, transparent, rgba(255,255,255,0.4), transparent);
		animation: shimmer 3s ease-in-out infinite;
	}

	.placeholder-row.shimmer:nth-child(2)::after { animation-delay: 0s; }
	.placeholder-row.shimmer:nth-child(3)::after { animation-delay: 0.3s; }
	.placeholder-row.shimmer:nth-child(4)::after { animation-delay: 0.6s; }
	.placeholder-row.shimmer:nth-child(5)::after { animation-delay: 0.9s; }

	@keyframes shimmer {
		0% { left: -100%; }
		50%, 100% { left: 100%; }
	}

	@media (max-width: 900px) {
		.container {
			grid-template-columns: 1fr;
			gap: var(--space-lg);
		}

		.dashboard-placeholder {
			max-width: 500px;
			margin: 0 auto;
		}
	}

	@media (max-width: 640px) {
		h2 {
			font-size: var(--font-size-2xl);
		}

		.dashboard-placeholder {
			max-width: 100%;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.placeholder-row.shimmer::after {
			animation: none;
		}
	}
</style>
