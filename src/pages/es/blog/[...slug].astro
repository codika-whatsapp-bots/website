---
import BlogPost from '../../../layouts/BlogPost.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
	const posts = await getCollection('blog', (entry) => !entry.data.draft);
	const localePosts = posts.filter((post) => post.id.startsWith('es/'));
	const enPosts = posts.filter((post) => post.id.startsWith('en/'));
	const localeSlugs = new Set(localePosts.map((p) => p.id.replace(/^es\//, '')));

	const allLocalePosts = [
		...localePosts,
		...enPosts.filter((post) => !localeSlugs.has(post.id.replace(/^en\//, ''))),
	];

	return allLocalePosts.map((post) => {
		const slug = post.id.replace(/^(en|es)\//, '');
		return {
			params: { slug },
			props: {
				post,
				otherPosts: allLocalePosts
					.filter((p) => p.id !== post.id)
					.sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
					.slice(0, 3),
			},
		};
	});
}

const { post, otherPosts } = Astro.props;
const { Content, headings } = await render(post);
---

<BlogPost post={post} headings={headings} otherPosts={otherPosts}>
	<Content />
</BlogPost>
