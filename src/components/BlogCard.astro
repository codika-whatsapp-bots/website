---
import { getLangFromLocale, useTranslations, getLocalePath } from '../i18n/utils';

const lang = getLangFromLocale(Astro.currentLocale);
const t = useTranslations(lang);

interface Props {
	title: string;
	description: string;
	date: Date;
	slug: string;
	tags: string[];
	readingTime: number;
	image?: string;
	imageAlt?: string;
}

const { title, description, date, slug, tags, readingTime, image, imageAlt } = Astro.props;

const dateFormatter = new Intl.DateTimeFormat(lang, {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
});

const href = getLocalePath(lang, `blog/${slug}`);
---

<a href={href} class="blog-card">
	<article>
		{image && (
			<div class="card-image">
				<img src={image} alt={imageAlt ?? title} loading="lazy" />
			</div>
		)}
		<div class="card-body">
			<div class="card-meta">
				<time datetime={date.toISOString()}>{dateFormatter.format(date)}</time>
				<span class="separator">&middot;</span>
				<span>{readingTime} {t('blog.minuteRead')}</span>
			</div>
			<h3>{title}</h3>
			<p>{description}</p>
			<div class="card-bottom">
				<div class="card-tags">
					{tags.slice(0, 3).map((tag) => (
						<span class="tag">{tag}</span>
					))}
				</div>
				<span class="read-more">{t('blog.readMore')} &rarr;</span>
			</div>
		</div>
	</article>
</a>

<style>
	.blog-card {
		display: block;
		background: var(--color-bg-alt);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		overflow: hidden;
		transition: border-color var(--transition-normal), box-shadow var(--transition-normal), transform var(--transition-normal);
	}

	.blog-card:hover {
		border-color: var(--color-border-strong);
		box-shadow: var(--shadow-md);
		transform: translateY(-2px);
	}

	.card-image {
		aspect-ratio: 16 / 9;
		overflow: hidden;
	}

	.card-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.4s ease;
	}

	.blog-card:hover .card-image img {
		transform: scale(1.03);
	}

	.card-body {
		padding: var(--space-sm) var(--space-md) var(--space-md);
		display: flex;
		flex-direction: column;
		gap: var(--space-xs);
	}

	.card-meta {
		display: flex;
		align-items: center;
		gap: 6px;
		font-size: var(--font-size-xs);
		color: var(--color-text-tertiary);
	}

	.separator {
		color: var(--color-text-muted);
	}

	h3 {
		font-family: var(--font-display);
		font-size: var(--font-size-lg);
		line-height: var(--line-height-snug);
		color: var(--color-text-primary);
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	p {
		font-size: var(--font-size-sm);
		color: var(--color-text-secondary);
		line-height: var(--line-height-normal);
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.card-bottom {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-xs);
		margin-top: auto;
	}

	.card-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 6px;
	}

	.tag {
		font-size: 11px;
		font-weight: 500;
		color: var(--color-primary);
		background: rgba(7, 94, 84, 0.06);
		padding: 2px 10px;
		border-radius: var(--radius-full);
	}

	.read-more {
		font-size: var(--font-size-sm);
		font-weight: 600;
		color: var(--color-primary);
		white-space: nowrap;
	}
</style>
