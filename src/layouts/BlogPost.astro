---
import Layout from './Layout.astro';
import Navigation from '../components/Navigation.astro';
import BlogHeader from '../components/BlogHeader.astro';
import BlogCard from '../components/BlogCard.astro';
import Footer from '../components/Footer.astro';
import { getLangFromLocale, useTranslations, getLocalePath, getAllLanguages } from '../i18n/utils';
import type { CollectionEntry } from 'astro:content';
import type { MarkdownHeading } from 'astro';

interface Props {
	post: CollectionEntry<'blog'>;
	headings?: MarkdownHeading[];
	otherPosts?: CollectionEntry<'blog'>[];
}

const { post, headings = [], otherPosts = [] } = Astro.props;
const lang = getLangFromLocale(Astro.currentLocale);
const t = useTranslations(lang);
const origin = Astro.site ?? Astro.url.origin;

const { title, description, date, updatedDate, author, tags, image, canonicalUrl } = post.data;

// Calculate reading time
const words = post.body?.split(/\s+/).length ?? 0;
const readingTime = Math.max(1, Math.ceil(words / 200));

// Build slug without locale prefix for hreflang
const slug = post.id.replace(/^(en|fr|nl|es|it|de)\//, '');

// Filter headings to h2 only for TOC
const tocHeadings = headings.filter((h) => h.depth === 2);

// Article schema markup
const articleSchema = {
	'@context': 'https://schema.org',
	'@type': 'Article',
	headline: title,
	description: description,
	author: {
		'@type': 'Person',
		name: author,
	},
	publisher: {
		'@type': 'Organization',
		name: 'Codika',
		url: 'https://codika.io',
	},
	datePublished: date.toISOString(),
	...(updatedDate && { dateModified: updatedDate.toISOString() }),
	...(image && { image: new URL(image, origin).href }),
	mainEntityOfPage: Astro.url.href,
};

// OG image
const ogImage = image ? new URL(image, origin).href : new URL('/og-image.png', origin).href;
---

<Layout
	title={`${title} | WhatsApp Bots by Codika`}
	description={description}
	pageType="home"
>
	<Fragment slot="head">
		{canonicalUrl && <link rel="canonical" href={canonicalUrl} />}

		<!-- Hreflang for blog post -->
		{getAllLanguages().map((l) => (
			<link rel="alternate" hreflang={l} href={new URL(getLocalePath(l, `blog/${slug}`), origin).href} />
		))}

		<!-- Article meta -->
		<meta property="og:type" content="article" />
		<meta property="article:published_time" content={date.toISOString()} />
		{updatedDate && <meta property="article:modified_time" content={updatedDate.toISOString()} />}
		{tags.map((tag) => <meta property="article:tag" content={tag} />)}
		<meta property="og:image" content={ogImage} />

		<!-- Article schema -->
		<script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
	</Fragment>

	<Navigation />
	<main class="blog-post-wrapper">
		<div class="blog-post-layout">
			<article class="blog-post">
				<BlogHeader
					title={title}
					date={date}
					updatedDate={updatedDate}
					author={author}
					readingTime={readingTime}
					tags={tags}
				/>
				{image && (
					<div class="blog-hero-image">
						<img src={image} alt={title} />
					</div>
				)}
				<div class="blog-content" id="blog-content">
					<slot />
				</div>
			</article>

			{tocHeadings.length > 0 && (
				<aside class="toc-sidebar" id="toc-sidebar">
					<nav class="toc" aria-label="Table of contents">
						<p class="toc-title">{t('blog.onThisPage')}</p>
						<ul>
							{tocHeadings.map((heading) => (
								<li class:list={[`toc-depth-${heading.depth}`]}>
									<a href={`#${heading.slug}`} class="toc-link" data-slug={heading.slug}>
										{heading.text}
									</a>
								</li>
							))}
						</ul>
					</nav>
				</aside>
			)}
		</div>

		{otherPosts.length > 0 && (
			<section class="discover-section">
				<h2>{t('blog.discoverMore')}</h2>
				<div class="discover-grid">
					{otherPosts.map((otherPost) => {
						const otherSlug = otherPost.id.replace(/^(en|fr|nl|es|it|de)\//, '');
						const otherWords = otherPost.body?.split(/\s+/).length ?? 0;
						const otherReadingTime = Math.max(1, Math.ceil(otherWords / 200));
						return (
							<BlogCard
								title={otherPost.data.title}
								description={otherPost.data.description}
								date={otherPost.data.date}
								slug={otherSlug}
								tags={otherPost.data.tags}
								readingTime={otherReadingTime}
								image={otherPost.data.image}
								imageAlt={otherPost.data.imageAlt}
							/>
						);
					})}
				</div>
			</section>
		)}
	</main>
	<Footer />
</Layout>

<script>
	function initToc() {
		const tocLinks = document.querySelectorAll<HTMLAnchorElement>('.toc-link');
		if (tocLinks.length === 0) return;

		const headingElements: HTMLElement[] = [];
		tocLinks.forEach((link) => {
			const slug = link.dataset.slug;
			if (slug) {
				const el = document.getElementById(slug);
				if (el) headingElements.push(el);
			}
		});

		if (headingElements.length === 0) return;

		let activeSlug = '';

		function updateActive() {
			const scrollY = window.scrollY;
			const offset = 120;

			let current = '';
			for (const heading of headingElements) {
				if (heading.offsetTop - offset <= scrollY) {
					current = heading.id;
				}
			}

			if (current !== activeSlug) {
				activeSlug = current;
				tocLinks.forEach((link) => {
					link.classList.toggle('active', link.dataset.slug === current);
				});
			}
		}

		let ticking = false;
		window.addEventListener('scroll', () => {
			if (!ticking) {
				requestAnimationFrame(() => {
					updateActive();
					ticking = false;
				});
				ticking = true;
			}
		}, { passive: true });

		updateActive();

		// Smooth scroll on click
		tocLinks.forEach((link) => {
			link.addEventListener('click', (e) => {
				e.preventDefault();
				const slug = link.dataset.slug;
				if (slug) {
					const target = document.getElementById(slug);
					if (target) {
						const top = target.offsetTop - 100;
						window.scrollTo({ top, behavior: 'smooth' });
						history.replaceState(null, '', `#${slug}`);
					}
				}
			});
		});
	}

	initToc();

	// Transform images into figures with captions and custom sizing
	// Convention: ![Caption text](/blog/image.jpg#w-500)
	//   - alt text → figcaption (if non-empty)
	//   - #w-NUMBER in src → max-width in px
	//   - #left in src → align left instead of center
	function initBlogImages() {
		const content = document.getElementById('blog-content');
		if (!content) return;

		content.querySelectorAll<HTMLImageElement>('img').forEach((img) => {
			const alt = img.getAttribute('alt')?.trim() ?? '';
			let src = img.getAttribute('src') ?? '';

			// Parse options from hash fragment
			const widthMatch = src.match(/#w-(\d+)/);
			const isLeft = src.includes('#left');

			// Clean hash from src
			src = src.replace(/#(w-\d+|left)/g, '').replace(/#$/, '');
			img.setAttribute('src', src);

			if (widthMatch) {
				img.style.maxWidth = `${widthMatch[1]}px`;
				img.style.width = '100%';
			}

			// Wrap in <figure>
			const figure = document.createElement('figure');
			figure.className = 'blog-figure';
			if (!isLeft) figure.classList.add('blog-figure--center');
			if (widthMatch) figure.style.maxWidth = `${widthMatch[1]}px`;

			if (alt) {
				const caption = document.createElement('figcaption');
				caption.textContent = alt;
				img.parentNode?.insertBefore(figure, img);
				figure.appendChild(img);
				figure.appendChild(caption);
			} else {
				img.parentNode?.insertBefore(figure, img);
				figure.appendChild(img);
			}
		});
	}

	initBlogImages();

	// Transform FAQ section from plain h3/p pairs into accordion
	function initBlogFaq() {
		const content = document.getElementById('blog-content');
		if (!content) return;

		// Find the FAQ h2 heading
		const faqHeading = content.querySelector<HTMLHeadingElement>(
			'h2[id*="frequently-asked"], h2[id*="questions-frequemment"], h2[id*="faq"]'
		);
		if (!faqHeading) return;

		// Collect all h3 + p pairs after the FAQ heading
		const faqs: { question: string; answer: string }[] = [];
		let el = faqHeading.nextElementSibling;
		while (el) {
			if (el.tagName === 'H3') {
				const question = el.textContent?.trim() ?? '';
				const answerEl = el.nextElementSibling;
				const answer = answerEl?.tagName === 'P' ? answerEl.innerHTML : '';
				faqs.push({ question, answer });
				// Skip the answer paragraph
				el = answerEl?.nextElementSibling ?? null;
			} else if (el.tagName === 'H2') {
				break; // Stop if we hit another h2
			} else {
				el = el.nextElementSibling;
			}
		}

		if (faqs.length === 0) return;

		// Remove original elements (h3s and ps)
		el = faqHeading.nextElementSibling;
		while (el) {
			const next = el.nextElementSibling;
			if (el.tagName === 'H2') break;
			el.remove();
			el = next;
		}

		// Also remove the <hr> before the FAQ if present
		const prevEl = faqHeading.previousElementSibling;
		if (prevEl?.tagName === 'HR') {
			prevEl.remove();
		}

		// Build accordion HTML
		const accordion = document.createElement('div');
		accordion.className = 'blog-faq-list';
		faqs.forEach((faq) => {
			const item = document.createElement('div');
			item.className = 'blog-faq-item';
			item.innerHTML = `
				<button class="blog-faq-trigger" aria-expanded="false">
					<span>${faq.question}</span>
					<svg class="blog-faq-chevron" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
						<path d="M5 7.5l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
					</svg>
				</button>
				<div class="blog-faq-answer">
					<div class="blog-faq-answer-inner">
						<p>${faq.answer}</p>
					</div>
				</div>
			`;
			accordion.appendChild(item);
		});

		// Insert accordion after the heading
		faqHeading.after(accordion);

		// Wire up accordion behavior
		const items = accordion.querySelectorAll('.blog-faq-item');
		items.forEach((item) => {
			const trigger = item.querySelector('.blog-faq-trigger') as HTMLButtonElement;
			const answer = item.querySelector('.blog-faq-answer') as HTMLElement;
			const inner = item.querySelector('.blog-faq-answer-inner') as HTMLElement;
			if (!trigger || !answer || !inner) return;

			trigger.addEventListener('click', () => {
				const isOpen = trigger.getAttribute('aria-expanded') === 'true';
				if (isOpen) {
					answer.style.height = answer.scrollHeight + 'px';
					requestAnimationFrame(() => {
						answer.style.height = '0';
						answer.style.opacity = '0';
					});
					trigger.setAttribute('aria-expanded', 'false');
					item.classList.remove('open');
				} else {
					// Close others
					items.forEach((other) => {
						if (other !== item && other.classList.contains('open')) {
							const ot = other.querySelector('.blog-faq-trigger') as HTMLButtonElement;
							const oa = other.querySelector('.blog-faq-answer') as HTMLElement;
							if (ot && oa) {
								oa.style.height = oa.scrollHeight + 'px';
								requestAnimationFrame(() => {
									oa.style.height = '0';
									oa.style.opacity = '0';
								});
								ot.setAttribute('aria-expanded', 'false');
								other.classList.remove('open');
							}
						}
					});
					answer.style.height = inner.scrollHeight + 'px';
					answer.style.opacity = '1';
					trigger.setAttribute('aria-expanded', 'true');
					item.classList.add('open');
				}
			});
		});
	}

	initBlogFaq();
</script>

<style>
	.blog-post-wrapper {
		max-width: 1100px;
		margin: 0 auto;
		padding: calc(var(--space-xl) + 60px) var(--space-md) var(--space-xl);
	}

	.blog-post-layout {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-lg);
		position: relative;
	}

	@media (min-width: 1024px) {
		.blog-post-layout {
			grid-template-columns: 1fr 220px;
		}
	}

	.blog-post {
		max-width: 740px;
		min-width: 0;
	}

	/* Table of Contents Sidebar */
	.toc-sidebar {
		display: none;
	}

	@media (min-width: 1024px) {
		.toc-sidebar {
			display: block;
			position: relative;
		}

		.toc {
			position: sticky;
			top: 100px;
		}
	}

	.toc-title {
		font-size: var(--font-size-xs);
		font-weight: 600;
		letter-spacing: var(--letter-spacing-wide);
		text-transform: uppercase;
		color: var(--color-text-tertiary);
		margin-bottom: 12px;
	}

	.toc ul {
		list-style: none;
		padding: 0;
		margin: 0;
		border-left: 1px solid var(--color-border);
	}

	.toc li {
		margin: 0;
	}

	.toc-depth-3 {
		padding-left: 12px;
	}

	.toc-link {
		display: block;
		padding: 6px 0 6px 16px;
		font-size: 13px;
		line-height: 1.4;
		color: var(--color-text-tertiary);
		border-left: 2px solid transparent;
		margin-left: -1px;
		transition: color var(--transition-fast), border-color var(--transition-fast);
		text-decoration: none;
	}

	.toc-link:hover {
		color: var(--color-text-secondary);
	}

	.toc-link.active {
		color: var(--color-primary);
		border-left-color: var(--color-primary);
		font-weight: 500;
	}

	/* Hero Image */
	.blog-hero-image {
		margin-bottom: var(--space-md);
		border-radius: var(--radius-lg);
		overflow: hidden;
	}

	.blog-hero-image img {
		width: 100%;
		height: auto;
		display: block;
	}

	/* Blog Content */
	.blog-content {
		font-family: var(--font-body);
		font-size: var(--font-size-base);
		line-height: var(--line-height-relaxed);
		color: var(--color-text-secondary);
	}

	.blog-content :global(h2) {
		font-family: var(--font-display);
		font-size: var(--font-size-2xl);
		color: var(--color-text-primary);
		margin-top: var(--space-lg);
		margin-bottom: var(--space-sm);
	}

	.blog-content :global(h3) {
		font-family: var(--font-display);
		font-size: var(--font-size-xl);
		color: var(--color-text-primary);
		margin-top: var(--space-md);
		margin-bottom: var(--space-sm);
	}

	.blog-content :global(p) {
		margin-bottom: var(--space-sm);
	}

	.blog-content :global(ul),
	.blog-content :global(ol) {
		margin-bottom: var(--space-sm);
		padding-left: var(--space-md);
	}

	.blog-content :global(li) {
		margin-bottom: 8px;
	}

	.blog-content :global(blockquote) {
		border-left: 3px solid var(--color-primary);
		padding-left: var(--space-sm);
		margin: var(--space-md) 0;
		color: var(--color-text-tertiary);
		font-style: italic;
	}

	.blog-content :global(code) {
		background-color: var(--color-bg-subtle);
		padding: 2px 6px;
		border-radius: 4px;
		font-size: 0.9em;
	}

	.blog-content :global(pre) {
		background-color: var(--color-bg-subtle);
		padding: var(--space-sm);
		border-radius: var(--radius-md);
		overflow-x: auto;
		margin-bottom: var(--space-sm);
	}

	.blog-content :global(pre code) {
		background: none;
		padding: 0;
	}

	.blog-content :global(a) {
		color: var(--color-primary);
		text-decoration: underline;
		text-underline-offset: 2px;
	}

	.blog-content :global(a:hover) {
		color: var(--color-primary-light);
	}

	.blog-content :global(img) {
		border-radius: var(--radius-md);
		margin: var(--space-md) 0;
		height: auto;
	}

	.blog-content :global(.blog-figure) {
		margin: var(--space-lg) 0;
	}

	.blog-content :global(.blog-figure--center) {
		margin-left: auto;
		margin-right: auto;
	}

	.blog-content :global(.blog-figure img) {
		margin: 0 0 var(--space-xs);
		width: 100%;
		display: block;
	}

	.blog-content :global(.blog-figure figcaption) {
		font-size: var(--font-size-xs);
		color: var(--color-text-tertiary);
		text-align: center;
		line-height: var(--line-height-normal);
	}

	.blog-content :global(hr) {
		border: none;
		border-top: 1px solid var(--color-border);
		margin: var(--space-lg) 0;
	}

	.blog-content :global(table) {
		width: 100%;
		border-collapse: collapse;
		margin-bottom: var(--space-sm);
	}

	.blog-content :global(th),
	.blog-content :global(td) {
		padding: 10px 14px;
		border: 1px solid var(--color-border);
		text-align: left;
	}

	.blog-content :global(th) {
		background-color: var(--color-bg-subtle);
		font-weight: 600;
	}

	.blog-content :global(strong) {
		color: var(--color-text-primary);
		font-weight: 600;
	}

	/* Blog FAQ Accordion */
	.blog-content :global(.blog-faq-list) {
		display: flex;
		flex-direction: column;
		margin-top: var(--space-sm);
	}

	.blog-content :global(.blog-faq-item) {
		border-bottom: 1px solid var(--color-border);
	}

	.blog-content :global(.blog-faq-item:first-child) {
		border-top: 1px solid var(--color-border);
	}

	.blog-content :global(.blog-faq-trigger) {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-sm);
		width: 100%;
		padding: var(--space-md) 0;
		cursor: pointer;
		font-family: var(--font-body);
		font-size: var(--font-size-base);
		font-weight: 600;
		color: var(--color-text-primary);
		line-height: var(--line-height-snug);
		text-align: left;
		background: none;
		border: none;
		transition: color var(--transition-normal);
	}

	.blog-content :global(.blog-faq-trigger:hover) {
		color: var(--color-primary);
	}

	.blog-content :global(.blog-faq-chevron) {
		flex-shrink: 0;
		color: var(--color-text-tertiary);
		transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), color var(--transition-normal);
	}

	.blog-content :global(.blog-faq-item.open .blog-faq-chevron) {
		transform: rotate(180deg);
		color: var(--color-primary);
	}

	.blog-content :global(.blog-faq-answer) {
		height: 0;
		opacity: 0;
		overflow: hidden;
		transition: height 0.35s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.3s ease;
	}

	.blog-content :global(.blog-faq-answer-inner) {
		padding: 0 0 var(--space-md);
	}

	.blog-content :global(.blog-faq-answer-inner p) {
		font-size: var(--font-size-sm);
		color: var(--color-text-secondary);
		line-height: var(--line-height-relaxed);
		margin-bottom: 0;
	}

	@media (prefers-reduced-motion: reduce) {
		.blog-content :global(.blog-faq-answer) {
			transition: none;
		}
		.blog-content :global(.blog-faq-chevron) {
			transition: none;
		}
	}

	/* Discover Section */
	.discover-section {
		margin-top: var(--space-xl);
		padding-top: var(--space-lg);
		padding-bottom: var(--space-xl);
		border-top: 1px solid var(--color-border);
	}

	.discover-section h2 {
		font-family: var(--font-display);
		font-size: var(--font-size-2xl);
		color: var(--color-text-primary);
		margin-bottom: var(--space-md);
	}

	.discover-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-md);
	}

	@media (min-width: 640px) {
		.discover-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (min-width: 900px) {
		.discover-grid {
			grid-template-columns: repeat(3, 1fr);
		}
	}
</style>
