---
import { getLangFromLocale, useTranslations } from '../i18n/utils';

const lang = getLangFromLocale(Astro.currentLocale);
const t = useTranslations(lang);
---

<section class="hero">
	<div class="hero-content reveal">
		<h1>
			<span>{t('hero.title.line1')}</span>
			<span>{t('hero.title.line2')}</span>
		</h1>
		<p class="hero-subtitle">{t('hero.subtitle')}</p>
		<div class="hero-ctas">
			<a href="mailto:hello@codika.io" class="cta-primary">
				{t('hero.cta')}
				<svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
					<path d="M3.333 8h9.334M8.667 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
				</svg>
			</a>
			<a href="#how-it-works" class="cta-secondary">{t('hero.cta.secondary')}</a>
		</div>
		<p class="hero-trust">{t('hero.trustSignal')}</p>
	</div>

	<div class="hero-visual reveal reveal-delay-2">
		<div class="chat-glow"></div>
		<div class="chat-mockup">
			<div class="chat-header">
				<div class="chat-avatar">
					<svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
						<path d="M12 2C6.477 2 2 6.477 2 12c0 1.89.525 3.66 1.438 5.168L2 22l4.832-1.438A9.955 9.955 0 0012 22c5.523 0 10-4.477 10-10S17.523 2 12 2z" fill="#25D366"/>
						<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z" fill="white"/>
					</svg>
				</div>
				<div class="chat-header-info">
					<span class="chat-name">Community Bot</span>
					<span class="chat-status">
						<span class="status-dot"></span>
						online
					</span>
				</div>
			</div>
			<div class="chat-body">
				<div class="chat-bubble user bubble-anim bubble-1">{t('hero.chat.user1')}</div>
				<div class="chat-bubble bot bubble-anim bubble-2">{t('hero.chat.bot1')}</div>
				<div class="chat-bubble user bubble-anim bubble-3">{t('hero.chat.user2')}</div>
				<div class="chat-bubble bot bubble-anim bubble-4">{t('hero.chat.bot2')}</div>
			</div>
		</div>
	</div>

	<!-- Decorative floating elements -->
	<div class="hero-decoration deco-1" aria-hidden="true"></div>
	<div class="hero-decoration deco-2" aria-hidden="true"></div>
	<div class="hero-decoration deco-3" aria-hidden="true"></div>
</section>

<style>
	.hero {
		padding: 140px var(--space-md) var(--space-xl);
		max-width: 1200px;
		margin: 0 auto;
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: var(--space-xl);
		align-items: center;
		position: relative;
		overflow: visible;
	}

	.hero-content {
		max-width: 560px;
	}

	h1 {
		font-size: clamp(2.25rem, 4.5vw, 3.25rem);
		line-height: var(--line-height-tight);
		letter-spacing: var(--letter-spacing-tight);
		margin-bottom: var(--space-md);
	}

	h1 span {
		display: block;
	}

	h1 span:last-child {
		color: var(--color-primary);
	}

	.hero-subtitle {
		font-size: var(--font-size-base);
		color: var(--color-text-secondary);
		line-height: var(--line-height-relaxed);
		margin-bottom: var(--space-lg);
		max-width: 480px;
	}

	.hero-ctas {
		display: flex;
		align-items: center;
		gap: var(--space-sm);
	}

	.cta-primary {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		padding: 14px 28px;
		background-color: var(--color-primary);
		color: var(--color-text-on-dark);
		border-radius: var(--radius-full);
		font-size: var(--font-size-base);
		font-weight: 600;
		border: 1px solid var(--color-primary);
		transition: background-color 0.3s ease, color 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
	}

	.cta-primary:hover {
		background-color: var(--color-primary-light);
		border-color: var(--color-primary-light);
		transform: translateY(-2px);
		box-shadow: 0 8px 30px rgba(7, 94, 84, 0.25);
	}

	.cta-primary:active {
		transform: translateY(0);
	}

	.cta-secondary {
		display: inline-flex;
		align-items: center;
		padding: 14px 28px;
		font-size: var(--font-size-base);
		font-weight: 600;
		color: var(--color-primary);
		border-radius: var(--radius-full);
		border: 1px solid var(--color-border-strong);
		transition: background-color 0.3s ease, color 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
	}

	.cta-secondary:hover {
		color: var(--color-primary-light);
		border-color: var(--color-primary);
		background-color: rgba(7, 94, 84, 0.04);
		transform: translateY(-2px);
	}

	.hero-trust {
		margin-top: var(--space-md);
		font-size: var(--font-size-xs);
		color: var(--color-text-tertiary);
		letter-spacing: 0.02em;
	}

	/* Chat visual container */
	.hero-visual {
		position: relative;
	}

	/* Gradient glow behind chat */
	.chat-glow {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		width: 110%;
		height: 110%;
		background: radial-gradient(
			ellipse at center,
			rgba(37, 211, 102, 0.12) 0%,
			rgba(7, 94, 84, 0.06) 40%,
			transparent 70%
		);
		border-radius: 50%;
		pointer-events: none;
		z-index: 0;
	}

	/* Chat mockup */
	.chat-mockup {
		background: var(--color-bg-alt);
		border-radius: var(--radius-xl);
		box-shadow:
			0 20px 60px rgba(0, 0, 0, 0.1),
			0 0 0 1px rgba(0, 0, 0, 0.03);
		overflow: hidden;
		max-width: 420px;
		margin-left: auto;
		position: relative;
		z-index: 1;
	}

	.chat-header {
		background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-light) 100%);
		padding: var(--space-sm) var(--space-md);
		display: flex;
		align-items: center;
		gap: var(--space-sm);
	}

	.chat-avatar {
		width: 36px;
		height: 36px;
		border-radius: 50%;
		background: rgba(255, 255, 255, 0.15);
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.chat-header-info {
		display: flex;
		flex-direction: column;
	}

	.chat-name {
		color: var(--color-text-on-dark);
		font-weight: 600;
		font-size: var(--font-size-sm);
	}

	.chat-status {
		color: var(--color-text-on-dark-muted);
		font-size: var(--font-size-xs);
		display: flex;
		align-items: center;
		gap: 4px;
	}

	.status-dot {
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: var(--color-primary-accent);
		display: inline-block;
		animation: pulse-dot 2s ease-in-out infinite;
	}

	@keyframes pulse-dot {
		0%, 100% { opacity: 1; }
		50% { opacity: 0.4; }
	}

	.chat-body {
		padding: var(--space-md);
		display: flex;
		flex-direction: column;
		gap: var(--space-xs);
		background: #ECE5DD;
	}

	.chat-bubble {
		padding: 10px 14px;
		border-radius: var(--radius-sm);
		font-size: var(--font-size-sm);
		line-height: var(--line-height-normal);
		max-width: 85%;
		color: var(--color-text-primary);
	}

	.chat-bubble.user {
		background: var(--color-bg-alt);
		align-self: flex-end;
		border-bottom-right-radius: 4px;
	}

	.chat-bubble.bot {
		background: #DCF8C6;
		align-self: flex-start;
		border-bottom-left-radius: 4px;
	}

	/* Staggered chat bubble entrance animation */
	.bubble-anim {
		opacity: 0;
		transform: translateY(10px);
		animation: bubble-in 0.4s ease-out forwards;
	}

	.bubble-1 { animation-delay: 0.6s; }
	.bubble-2 { animation-delay: 1.2s; }
	.bubble-3 { animation-delay: 2.0s; }
	.bubble-4 { animation-delay: 2.6s; }

	@keyframes bubble-in {
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	/* Decorative floating elements */
	.hero-decoration {
		position: absolute;
		border-radius: 50%;
		pointer-events: none;
		z-index: 0;
	}

	.deco-1 {
		width: 8px;
		height: 8px;
		background: var(--color-primary-accent);
		opacity: 0.3;
		top: 20%;
		right: 8%;
		animation: float-slow 6s ease-in-out infinite;
	}

	.deco-2 {
		width: 6px;
		height: 6px;
		background: var(--color-primary);
		opacity: 0.2;
		bottom: 25%;
		right: 2%;
		animation: float-slow 8s ease-in-out infinite 1s;
	}

	.deco-3 {
		width: 10px;
		height: 10px;
		background: var(--color-primary-accent);
		opacity: 0.15;
		top: 30%;
		left: 48%;
		animation: float-slow 7s ease-in-out infinite 2s;
	}

	@keyframes float-slow {
		0%, 100% { transform: translateY(0); }
		50% { transform: translateY(-12px); }
	}

	@media (max-width: 1024px) {
		.hero {
			gap: var(--space-lg);
		}

		.chat-mockup {
			max-width: 360px;
		}
	}

	@media (max-width: 768px) {
		.hero {
			grid-template-columns: 1fr;
			padding: 120px var(--space-md) var(--space-lg);
			gap: var(--space-lg);
		}

		.hero-content {
			text-align: center;
			max-width: 100%;
		}

		.hero-subtitle {
			max-width: 100%;
		}

		.hero-ctas {
			justify-content: center;
			flex-wrap: wrap;
		}

		.chat-mockup {
			margin: 0 auto;
			max-width: 360px;
		}

		.hero-decoration {
			display: none;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.bubble-anim {
			opacity: 1;
			transform: none;
			animation: none;
		}

		.status-dot {
			animation: none;
		}

		.hero-decoration {
			animation: none;
		}
	}
</style>
