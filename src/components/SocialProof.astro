---
import { getLangFromLocale, useTranslations } from '../i18n/utils';

const lang = getLangFromLocale(Astro.currentLocale);
const t = useTranslations(lang);

const stats = [
	{ number: t('socialProof.stat1.number'), label: t('socialProof.stat1.label') },
	{ number: t('socialProof.stat2.number'), label: t('socialProof.stat2.label') },
	{ number: t('socialProof.stat3.number'), label: t('socialProof.stat3.label') },
];
---

<section class="social-proof">
	<div class="stats-card reveal">
		{stats.map((stat, i) => (
			<>
				<div class="stat">
					<span class="stat-number">{stat.number}</span>
					<span class="stat-label">{stat.label}</span>
				</div>
				{i < stats.length - 1 && <div class="stat-divider" />}
			</>
		))}
	</div>
</section>

<style>
	.social-proof {
		padding: 0 var(--space-md);
		position: relative;
		z-index: 2;
		margin-top: -16px;
		margin-bottom: var(--space-xl);
	}

	.stats-card {
		max-width: 720px;
		margin: 0 auto;
		display: flex;
		justify-content: center;
		align-items: center;
		gap: var(--space-lg);
		padding: var(--space-md) var(--space-lg);
		background: rgba(255, 255, 255, 0.85);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
		border-radius: var(--radius-xl);
		box-shadow:
			0 4px 24px rgba(0, 0, 0, 0.06),
			0 0 0 1px rgba(0, 0, 0, 0.03);
	}

	.stat {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 4px;
	}

	.stat-number {
		font-family: var(--font-display);
		font-size: var(--font-size-3xl);
		color: var(--color-primary);
		line-height: var(--line-height-tight);
	}

	.stat-label {
		font-size: var(--font-size-sm);
		color: var(--color-text-tertiary);
		font-weight: 500;
		text-align: center;
	}

	.stat-divider {
		width: 1px;
		height: 40px;
		background: var(--color-border-strong);
		flex-shrink: 0;
	}

	@media (max-width: 768px) {
		.social-proof {
			margin-top: -20px;
		}

		.stats-card {
			gap: var(--space-md);
			padding: var(--space-sm) var(--space-md);
		}

		.stat-number {
			font-size: var(--font-size-2xl);
		}

		.stat-label {
			font-size: var(--font-size-xs);
			text-align: center;
		}

		.stat-divider {
			height: 32px;
		}
	}
</style>
