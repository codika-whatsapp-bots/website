---
import { getLangFromLocale, useTranslations } from '../i18n/utils';

const lang = getLangFromLocale(Astro.currentLocale);
const t = useTranslations(lang);

const steps = [
	{
		number: t('howItWorks.1.number'),
		title: t('howItWorks.1.title'),
		description: t('howItWorks.1.description'),
		icon: `<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/><path d="M8 9h8M8 13h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>`,
	},
	{
		number: t('howItWorks.2.number'),
		title: t('howItWorks.2.title'),
		description: t('howItWorks.2.description'),
		icon: `<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>`,
	},
	{
		number: t('howItWorks.3.number'),
		title: t('howItWorks.3.title'),
		description: t('howItWorks.3.description'),
		icon: `<path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/><path d="M12 15l-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>`,
	},
];
---

<section class="how-it-works" id="how-it-works">
	<div class="container">
		<div class="section-header reveal">
			<p class="eyebrow">{t('howItWorks.eyebrow')}</p>
			<h2>{t('howItWorks.title')}</h2>
		</div>
		<div class="steps">
			{steps.map((step, i) => (
				<div class={`step reveal reveal-delay-${i + 1}`}>
					<div class="step-header">
						<div class="step-number-circle">
							<span class="step-number">{step.number}</span>
						</div>
						{i < steps.length - 1 && <div class="step-connector" />}
					</div>
					<div class="step-icon">
						<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true" set:html={step.icon} />
					</div>
					<h3>{step.title}</h3>
					<p>{step.description}</p>
				</div>
			))}
		</div>
	</div>
</section>

<style>
	.how-it-works {
		padding: var(--space-2xl) var(--space-md);
		background-color: var(--color-bg-alt);
	}

	.container {
		max-width: 1000px;
		margin: 0 auto;
	}

	.section-header {
		margin-bottom: var(--space-xl);
	}

	.eyebrow {
		margin-bottom: var(--space-sm);
	}

	h2 {
		font-size: var(--font-size-3xl);
		max-width: 600px;
	}

	.steps {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--space-lg);
	}

	.step {
		position: relative;
	}

	.step-header {
		display: flex;
		align-items: center;
		margin-bottom: var(--space-md);
		position: relative;
	}

	.step-number-circle {
		width: 48px;
		height: 48px;
		border-radius: 50%;
		background: var(--color-primary);
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
		position: relative;
		z-index: 1;
	}

	.step-number {
		font-family: var(--font-body);
		font-size: var(--font-size-sm);
		font-weight: 700;
		color: var(--color-text-on-dark);
		letter-spacing: -0.02em;
	}

	.step-connector {
		position: absolute;
		left: 48px;
		top: 50%;
		width: calc(100% - 16px);
		height: 2px;
		background: linear-gradient(90deg, var(--color-primary) 0%, rgba(7, 94, 84, 0.15) 100%);
		transform: translateY(-50%);
	}

	.step-icon {
		width: 40px;
		height: 40px;
		border-radius: var(--radius-sm);
		background: rgba(7, 94, 84, 0.08);
		display: flex;
		align-items: center;
		justify-content: center;
		margin-bottom: var(--space-sm);
		color: var(--color-primary);
	}

	h3 {
		font-family: var(--font-body);
		font-weight: 600;
		font-size: var(--font-size-md);
		margin-bottom: var(--space-xs);
		line-height: var(--line-height-snug);
	}

	p {
		font-size: var(--font-size-sm);
		color: var(--color-text-secondary);
		line-height: var(--line-height-relaxed);
	}

	@media (max-width: 768px) {
		.steps {
			grid-template-columns: 1fr;
			gap: var(--space-md);
		}

		.step-connector {
			display: none;
		}

		h2 {
			font-size: var(--font-size-2xl);
		}
	}
</style>
